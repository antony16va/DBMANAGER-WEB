{
  "global": {
    "descripcion": "Reglas generales", 
    "case": "UPPER",
    "allowed_characters_regex": "^[A-Z0-9_]+$",
    "max_length_default": 30,
    "separador_palabras": "_"
  },

  "tabla": {
    "descripcion": "Reglas para tablas",
    "prefijos_validos": ["MAE", "TAB", "CAB", "DET", "AUD", "TMP"],
    "regex_nombre": "^[A-Z]{3}_[A-Z0-9_]+$",
    "max_length": 30,
    "usa_correlativo": true,
    "correlativo": {
      "descripcion": "Correlativo opcional al final del nombre de tabla",
      "longitud": 2,
      "regex": "^[0-9]{2}$",
      "separador": "_"
    }
  },

  "columna": {
    "descripcion": "Reglas para nombres de columnas",
    "prefijos_validos": ["C","B","N","D"],
    "regex_nombre": "^[A-Z]{1}_[A-Z0-9_]+(_PK)?$",
    "max_length": 30,
    "prefijos_tipo_dato": {
      "CHAR": "C",
      "VARCHAR": "C",
      "VARCHAR2": "C",
      "CLOB": "C",
      "BLOB": "B",
      "TEXT": "C",
      "INTEGER": "N",
      "INT": "N",
      "SMALLINT": "N",
      "BIGINT": "N",
      "NUMBER": "N",
      "NUMERIC": "N",
      "DECIMAL": "N",
      "FLOAT": "N",
      "REAL": "N",
      "DOUBLE": "N",
      "DATE": "D",
      "TIMESTAMP": "D"
    },
    "pk": {
      "descripcion": "Reglas para columnas que son parte de la clave primaria",
      "requiere_sufijo_pk": true,
      "sufijo_pk": "_PK"
    },
    "fk": {
      "descripcion": "Reglas para columnas que son clave foránea",
      "prohibir_sufijo_pk_en_fk": true
    },
    "correlativo": {
      "descripcion": "Correlativo opcional al final del nombre del campo",
      "longitud": 2,
      "regex": "^[0-9]{2}$",
      "separador": "_"
    }
  },

  "constant": {
    "descripcion": "Reglas para las constantes",
    "max_length": 30,
    "correlativo": {
      "descripcion": "Correlativo opcional al final del nombre de la constante",
      "longitud": 2,
      "regex": "^[0-9]{2}$",
      "separador": "_"
    }
  },
  
  "constraint": {
    "descripcion": "Reglas para constraints (PK, FK, UK, CK)",
    "prefijo": "CST_",
    "tipos_validos": ["PK", "FK", "UK", "CK"],
    "formato": "CST_<TABLA>_<TIPO>[_NN]",
    "regex_nombre": "^CST_[A-Z0-9_]+_(PK|FK|UK|CK)(_[0-9]{2})?$",
    "max_length": 30,
    "correlativo": {
      "descripcion": "Correlativo opcional al final del nombre de la constante",
      "longitud": 2,
      "regex": "^[0-9]{2}$",
      "separador": "_"
    }
  },
  
  "servidor": {
    "descripcion": "Reglas para DBLINK / Foreign Server",
    "prefijo": "SRV_",
    "formato": "SRV_<USER>[_NN]",
    "regex_nombre": "^SRV_[A-Z0-9_]+(_[0-9]{2})?$",
    "max_length": 30,
    "correlativo": {
      "usa_correlativo": true,
      "longitud": 2,
      "regex": "^[0-9]{2}$",
      "separador": "_"
    }
  },
  
  "function": {
    "descripcion": "Reglas para FUNCTIONS",
    "prefijo": "FN_",
    "formato": "FN_<DESCRIPCION>",
    "regex_nombre": "^FN_[A-Z0-9_]+$",
    "max_length": 30
  },

  "index": {
  "descripcion": "Reglas para INDEX",
  "prefijo": "INX_",
  "formato": "INX_<TABLA>[_TIPO][_NN]",
  "regex_nombre": "^INX_[A-Z0-9_]+(_[A-Z0-9]{2,3})?(_[0-9]{2})?$",
  "max_length": 30,
    "correlativo": {
      "usa_correlativo": true,
      "longitud": 2,
      "regex": "^[0-9]{2}$",
      "separador": "_"
    }
  },

  "materialized_view": {
    "descripcion": "Reglas para las vistas materializadas",
    "prefijo": "VM_",
    "formato": "VM_<DESCRIPCION>",
    "regex_nombre": "^VM_[A-Z0-9_]",
    "max_length": 30
  },

  "parametros": {
    "descripcion": "Reglas para los parametros",
    "formato": "P[I-O]",
    "nota": "I = parámetro de entrada (IN), O = parámetro de salida (OUT)",
    "max_length": 30
  },

   "sequence": {
    "descripcion": "Reglas para SEQUENCE",
    "prefijo": "SQ_",
    "formato": "SQ_<DESCRIPCION>[_NN]",
    "regex_nombre": "^SQ_[A-Z0-9_]+(_[0-9]{2})?$",
    "max_length": 30,
    "correlativo": {
      "usa_correlativo": true,
      "longitud": 2,
      "regex": "^[0-9]{2}$",
      "separador": "_"
    }
  },

  "procedure": {
  "descripcion": "Reglas para los STORE PROCEDURES",
  "prefijo": "SP_",
  "formato": "SP_<DEDESCRIPCION>[_NN]",
  "regex_nombre": "^SP_[A-Z0-9_]+(_[0-9]{2})?$",
  "max_length": 30
  },

  "tablespace": {
    "descripcion": "Reglas para TABLESPACE",
    "prefijo": "TBS_",
    "formato": "TBS_<ACRONIMO_SOFTWARE>_<PROCESO>[_TIPO][_NN]",
    "tipos_validos": ["DAT", "INX", "BIN", "TMP"],
    "regex_nombre": "^TBS_[A-Z0-9_]+$",
    "max_length": 30,
    "correlativo": {
      "usa_correlativo": true,
      "longitud": 2,
      "regex": "^[0-9]{2}$",
      "separador": "_"
    }
  },

    "temporary_table": {
    "descripcion": "Reglas para TEMPORARY TABLE",
    "prefijo": "TMP_",
    "formato": "TMP_<DESCRIPCION>[_NN]",
    "regex_nombre": "^TMP_[A-Z0-9_]+(_[0-9]{2})?$",
    "max_length": 30,
    "correlativo": {
      "usa_correlativo": true,
      "longitud": 2,
      "regex": "^[0-9]{2}$",
      "separador": "_"
    }
  },

  "trigger": {
    "descripcion": "Reglas para TRIGGERS",
    "prefijo": "TRG_",
    "tipos_validos": ["INS", "ACT", "ELI"],
    "formato": "TRG_<OBJETO>_<TIPO>",
    "regex_nombre": "^TRG_[A-Z0-9_]+_(INS|ACT|ELI)$",
    "max_length": 30
  },

  "function_trigger": {
    "descripcion": "Funciones usadas por triggers (misma regla que FUNCTION)",
    "hereda_de": "function"
  },

  "type": {
    "descripcion": "Reglas para TYPE (OT, CT)",
    "prefijo": "TYP_",
    "tipos_validos": ["OT", "CT"],
    "formato": "TYP_<TIPO>_<OBJETIVO>",
    "regex_nombre": "^TYP_(OT|CT)_[A-Z0-9_]+$",
    "max_length": 30
  },

  "foreign_table": {
    "descripcion": "Reglas para tablas foráneas (heredan reglas de TABLE)",
    "hereda_de": "tabla"
  },

  "view": {
    "descripcion": "Reglas para VIEW",
    "prefijo": "VW_",
    "formato": "VW_<DESCRIPCION>",
    "regex_nombre": "^VW_[A-Z0-9_]+$",
    "max_length": 30
  },

  "variable": {
    "descripcion": "Regla para las variables",
    "prefijo": "V[I,C,D,N,R]",
    "nota": "I=integer, C=char/varchar, D=date, N=numeric/number, R=registro",
    "formato": "V[I,C,D,N,R]_<DESCRIPCION>"
  }
}
